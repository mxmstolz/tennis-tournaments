# Neon Postgres connection string (pooled, with sslmode=require)
NUXT_DATABASE_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Password the Orga uses to log into the admin area
NUXT_ADMIN_PASSWORD="change-me"

# Secret for sealing the session cookie. Must be at least 32 characters.
NUXT_SESSION_PASSWORD="please-change-this-to-a-long-random-string"
